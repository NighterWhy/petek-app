{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/petek-backend/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/petek-backend/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/petek-backend",
  "projects": {
    "auth": {
      "type": "application",
      "root": "apps/auth",
      "entryFile": "main",
      "sourceRoot": "apps/auth/src",
      "compilerOptions": {
        "tsConfigPath": "apps/auth/tsconfig.app.json"
      }
    },
    "chat": {
      "type": "application",
      "root": "apps/chat",
      "entryFile": "main",
      "sourceRoot": "apps/chat/src",
      "compilerOptions": {
        "tsConfigPath": "apps/chat/tsconfig.app.json"
      }
    },
    "listings": {
      "type": "application",
      "root": "apps/listings",
      "entryFile": "main",
      "sourceRoot": "apps/listings/src",
      "compilerOptions": {
        "tsConfigPath": "apps/listings/tsconfig.app.json"
      }
    },
    "notifications": {
      "type": "application",
      "root": "apps/notifications",
      "entryFile": "main",
      "sourceRoot": "apps/notifications/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notifications/tsconfig.app.json",
        "assets": [{ "include": "mail/assets/**", "outDir": "dist/apps/notifications" }],
        "watchAssets": true
      }
    },
    "petek-backend": {
      "type": "application",
      "root": "apps/petek-backend",
      "entryFile": "main",
      "sourceRoot": "apps/petek-backend/src",
      "compilerOptions": {
        "tsConfigPath": "apps/petek-backend/tsconfig.app.json"
      }
    }
  }
}